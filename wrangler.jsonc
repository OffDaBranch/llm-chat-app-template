/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "llm-chat-app-template-main",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-10",
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "llm-chat-app-template-main-db",
      "database_id": "927af65b-7880-4f81-bfc7-aa4a53ade83c"
    }
  ],
  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "llm-chat-app-template-main-files"
    }
  ],
  "vars": {
    "APP_ENV": "dev",
    "DEFAULT_MODEL": "@cf/meta/llama-3.3-70b-instruct"
  },
  "upload_source_maps": true,
  "compatibility_flags": [
    "nodejs_compat"
  ]
}